{
  "name": "sazanami",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "bun run --filter sazanami-web dev",
    "dev:all": "bun run dev & bun run dev:websocket; wait",
    "dev:websocket": "bun run --filter sazanami-websocket dev",
    "dev:web": "bun run --filter sazanami-web dev",
    "build": "bun run --filter sazanami-web build",
    "build:websocket": "bun run --filter sazanami-websocket build",
    "preview": "bun run --filter sazanami-web preview",
    "check": "bun run --filter sazanami-web check",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "db:generate": "bun run --filter sazanami-web db:generate",
    "db:migrate": "bun run --filter sazanami-web db:migrate",
    "db:studio": "bun run --filter sazanami-web db:studio",
    "test": "bun run --filter sazanami-web test",
    "test:unit": "bun run --filter sazanami-web test:unit",
    "test:e2e": "bun run --filter sazanami-web test:e2e"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.11.0",
    "globals": "^16.3.0",
    "typescript-eslint": "^8.38.0",
    "@eslint/compat": "^1.3.1",
    "@eslint/js": "^9.32.0"
  }
}
