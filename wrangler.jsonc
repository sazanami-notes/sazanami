{
	"name": "sazanami-web",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"compatibility_date": "2025-05-12",
	"vars": {
		"STORAGE_DRIVER": "local"
	},
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": ".svelte-kit/cloudflare",
		"binding": "ASSETS",
		"run_worker_first": true
	}
}
