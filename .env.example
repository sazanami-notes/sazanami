# Turso Database Configuration
TURSO_DATABASE_URL="file:local.db"
TURSO_AUTH_TOKEN='dummy-token'

# BetterAuth Config
BETTER_AUTH_SECRET="dummy-secret-for-example"
BETTER_AUTH_URL=http://localhost:5173 #Base URL of your app

# Google Credentials 
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Realtime WebSocket endpoint
PUBLIC_WEBSOCKET_URL=http://127.0.0.1:8787

# SMTP Credentials
#SMTP_USER=""
#SMTP_PASS=""
#SMTP_FROM="onboarding@resend.dev"
#SMTP_HOST="smtp.resend.com"
#SMTP_PORT="465"
#SMTP_SECURE="true"

# Storage Configuration
# 'local' (default) saves files to static/uploads/
# 's3' uses S3-compatible storage
STORAGE_DRIVER=local

# S3-compatible storage settings (required when STORAGE_DRIVER=s3)
#S3_REGION=us-east-1
#S3_BUCKET=your-bucket-name
#S3_ACCESS_KEY_ID=your-access-key
#S3_SECRET_ACCESS_KEY=your-secret-key
#S3_ENDPOINT=        # optional: custom endpoint for MinIO etc.
#S3_PUBLIC_URL=      # optional: CDN or custom public URL base
